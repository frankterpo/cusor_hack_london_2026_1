# Copy to `.env.local` for `vercel dev`, or set the same keys in the Vercel project
# (Project Settings → Environment Variables). Never commit real secrets.

# --- Judge portal + session cookie (public/api/auth.js) ---
# Password shown on /judge login gate
SITE_PASSWORD=change-me-judge-portal
# HMAC secret for auth_token cookie (use a long random string)
AUTH_SECRET=change-me-long-random-secret

# --- Supabase (public/api/_lib/db.js, _lib/storage.js) ---
# REST + Storage for submissions, judge responses, JSON blobs
SUPABASE_PROJECT_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_SECRET=your-service-role-key
SUPABASE_ANON_PUBLIC_KEY=your-anon-key
# Optional: defaults to cursor-hackathon-manager
# SUPABASE_STORAGE_BUCKET=cursor-hackathon-manager

# --- Optional: GitHub metrics / analysis (public/api/_lib/github-analysis.js) ---
# GITHUB_TOKEN=ghp_...
# (aliases: GITHUB_PAT or GH_TOKEN)

# --- Optional: AI write-ups in admin (public/api/_lib/ai-analysis.js) ---
# OPENCODE_API_KEY=...
