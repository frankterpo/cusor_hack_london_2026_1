# Copy values into Vercel → Project → Settings → Environment Variables (no trailing slash on URLs).

# Gate for /admin and /judge HTML (guild static). Vercel UI may show lowercase; these names are read:
# SITE_PASSWORD, site_password, or Site_Password
SITE_PASSWORD=

# Optional separate signing secret for auth cookies. If omitted, a secret is derived from SITE_PASSWORD.
# AUTH_SECRET=

# Static board → Next credits app (same team: use your credits deployment origin, no trailing slash).
# Example: https://your-credits-app.vercel.app
CREDITS_APP_URL=
