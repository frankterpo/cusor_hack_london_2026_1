{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "python3 scripts/build_site.py",
  "outputDirectory": "dist",
  "framework": null,
  "cleanUrls": true,
  "routes": [
    {
      "src": "/credits-portal/(.*)",
      "dest": "${CREDITS_APP_URL}/credits/$1",
      "env": ["CREDITS_APP_URL"]
    },
    {
      "src": "/credits-portal",
      "dest": "${CREDITS_APP_URL}/credits/event/cursor-hackathon-london-2026/redeem",
      "env": ["CREDITS_APP_URL"]
    }
  ],
  "headers": [
    {
      "source": "/api/repo/(.*)/ai",
      "headers": [
        { "key": "Content-Type", "value": "text/plain; charset=utf-8" },
        { "key": "Cache-Control", "value": "public, max-age=0, s-maxage=300, must-revalidate" }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Content-Type", "value": "application/json; charset=utf-8" },
        { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate, max-age=0" }
      ]
    },
    {
      "source": "/(.*)\\.(css|js|png|svg|ico|woff2)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600, s-maxage=86400" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" }
      ]
    }
  ]
}
